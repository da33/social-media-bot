# 環境變數範例
# 複製此檔案為 .env 並填入你的資訊

# Instagram Graph API（官方）
IG_ACCESS_TOKEN=你的Instagram_Access_Token
IG_USER_ID=你的Instagram_User_ID

# Threads API（官方）
THREADS_ACCESS_TOKEN=你的Threads_Access_Token
THREADS_USER_ID=你的Threads_User_ID

# Twitter API 憑證
# 前往 https://developer.twitter.com/ 申請
TW_API_KEY=你的API_Key
TW_API_SECRET=你的API_Secret
TW_ACCESS_TOKEN=你的Access_Token
TW_ACCESS_SECRET=你的Access_Token_Secret

# 推廣連結
PROMOTION_LINK=https://rggo5269.com/#/ag/win99
